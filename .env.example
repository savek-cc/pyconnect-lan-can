# Required: IP of the ESP32 running the ECB1 bridge firmware.
BRIDGE_HOST=192.168.1.50

# Optional overrides — defaults shown in comments.

# BRIDGE_PORT=28081
# LANC_NODE=0x0C             # CAN node ID the emulator impersonates as the LAN C
# SRC_NODE=0x3E              # CAN node ID used when the emulator issues RMIs
# NMT_NODE=                  # Override NMT/presence-ping ID (defaults to LANC_NODE)
# ADVERTISE_IP=              # Force the IP advertised via UDP discovery
# IP_FOR=8.8.8.8             # Target used only for local-IP autodetection
# UUID=                      # Override gateway UUID
# VERSION=1                  # Gateway version byte
# TCP_PORT=56747
# UDP_PORT=56747
# GATEWAY_RMI_INTERVAL=60    # Set to 0 to disable the 60 s LAN-C RMI loop
# HEARTBEAT_INTERVAL=2       # Set to 0 to disable NMT self-heartbeat
# NO_WARM_SWEEP=false        # true to skip the PDO mirror-sweep on connect
# VERBOSE=false              # true for DEBUG logging
